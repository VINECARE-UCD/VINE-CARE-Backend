# VineCare Backend — Environment Variables Template
# Copy this file to .env and fill in your actual values

# ==========================================
# AWS Configuration
# ==========================================
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here
AWS_S3_BUCKET=vine-care-bucket

# ==========================================
# Database Configuration (Aurora PostgreSQL)
# ==========================================
DB_HOST=vine-care-postgres.xxxxx.eu-central-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=vinecare
DB_USER=postgres
DB_PASSWORD=your-strong-password-here

# ==========================================
# Django Configuration
# ==========================================
DEBUG=False
SECRET_KEY=generate-with-django-admin-shell
ALLOWED_HOSTS=*.compute.amazonaws.com,vine-care-alb-123456.eu-central-1.elb.amazonaws.com

# ==========================================
# Microservice URLs (Inter-Service Communication)
# ==========================================
DATA_COLLECTION_URL=http://vine-care-instance-data-collection:8000
NOTIFICATION_URL=http://vine-care-instance-notification:8001
PHENOLOGY_URL=http://vine-care-instance-phenology:8002

# ==========================================
# Email/Notification Configuration (Optional)
# ==========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-app-password
# FROM_EMAIL=noreply@vinecare.com

# ==========================================
# Logging Configuration
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=/var/log/vinecare/backend.log

# ==========================================
# Feature Flags (Optional)
# ==========================================
# ENABLE_ML_PREDICTIONS=True
# ENABLE_DRONE_PROCESSING=True
# ENABLE_NOTIFICATIONS=True
